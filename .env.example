# === GoClaw Gateway Connection ===
# Required: GoClaw gateway server URL
GOCLAW_SERVER=http://localhost:18790

# Optional: Bearer token for authentication (determines RBAC role)
GOCLAW_TOKEN=

# Optional: Default user ID for multi-tenant scoping
GOCLAW_USER_ID=

# === MCP HTTP Transport ===
# Port for Streamable HTTP transport (default: 3100)
GOCLAW_MCP_PORT=3100

# Comma-separated allowed origins for CORS (default: localhost)
GOCLAW_MCP_ALLOWED_ORIGINS=localhost,127.0.0.1

# Rate limit: requests per minute per session (default: 60)
GOCLAW_MCP_RATE_LIMIT_RPM=60

# === Logging ===
# Log level: debug, info, warn, error (default: info)
GOCLAW_LOG_LEVEL=info
